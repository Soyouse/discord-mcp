{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "_comment": "Gate mutation : cliquet anti-régression. break = plancher dur (CI/push échoue en dessous). Monter break au niveau de high quand le score grimpe — JAMAIS le redescendre.",
  "packageManager": "npm",
  "testRunner": "vitest",
  "reporters": ["html", "clear-text", "progress"],
  "coverageAnalysis": "perTest",
  "mutate": [
    "lib/core/client.js",
    "lib/http-auth.js",
    "lib/rate-monitor.js",
    "lib/registry.js",
    "handlers/*.js",
    "dispatch.js",
    "incidents.js"
  ],
  "thresholds": {
    "high": 85,
    "low": 80,
    "break": 80
  }
}
